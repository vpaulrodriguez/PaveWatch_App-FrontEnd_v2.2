<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@android:color/white">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reportar Bache"
            android:textColor="#02303A"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_centerVertical="true"/>

        <ImageButton
            android:id="@+id/btn_cerrar_dialog"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#FF0000" />
    </RelativeLayout>

    <ImageView
        android:id="@+id/img_foto_bache"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:layout_marginTop="20dp"
        android:background="#E0E0E0"
        android:scaleType="fitCenter"
        android:padding="80dp" app:tint="#888888"
        android:src="@android:drawable/ic_menu_camera" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Toca la imagen arriba para subir una foto de tu galería."
        android:textAlignment="center"
        android:textColor="#777777"
        android:textSize="12sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Recuerda: Subir reportes falsos ocasionará el bloqueo permanente de tu cuenta."
        android:textColor="#D32F2F"
        android:textStyle="bold"
        android:textSize="12sp"
        android:textAlignment="center"/>

    <Button
        android:id="@+id/btn_subir_foto"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="24dp"
        android:enabled="false"
        android:text="CONFIRMAR Y SUBIR"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@android:color/white" />

</LinearLayout>